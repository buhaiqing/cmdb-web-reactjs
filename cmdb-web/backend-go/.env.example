# Server
GIN_MODE=release
PORT=8000

# Database
# 支持的数据库类型：sqlite, postgres, mysql
# 开发环境默认使用 SQLite
DATABASE_TYPE=sqlite
DATABASE_URL=./cmdb.db

# PostgreSQL 示例（生产环境）
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://cmdb:cmdb@localhost:5432/cmdb?sslmode=disable

# MySQL 示例（生产环境）
# DATABASE_TYPE=mysql
# DATABASE_URL=user:password@tcp(127.0.0.1:3306)/cmdb?charset=utf8mb4&parseTime=True&loc=Local

# JWT
SECRET_KEY=cmdb-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Project
PROJECT_NAME=CMDB Backend
