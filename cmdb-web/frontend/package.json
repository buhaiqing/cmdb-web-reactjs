{
  "name": "cmdb-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "TEST_MODE=mock playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:full": "TEST_MODE=full playwright test",
    "test:e2e:module": "TEST_MODE=mock playwright test --projects=",
    "test:e2e:module:full": "TEST_MODE=full playwright test --projects=",
    "test:e2e:failed": "TEST_MODE=mock playwright test --last-failed",
    "test:e2e:failed:full": "TEST_MODE=full playwright test --last-failed"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@antv/g6": "^5.1.0",
    "antd": "^6.3.5",
    "axios": "^1.7.0",
    "dayjs": "^1.11.13",
    "js-cookie": "^3.0.5",
    "next": "^15.5.15",
    "react": "^19.0.5",
    "react-dom": "^19.0.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.15",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript": "^5.6.0"
  }
